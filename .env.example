MONGODB_URI=mongodb://127.0.0.1:27017/torlash
PORT=3000

# Google OAuth — יש להוסיף ב-Google Cloud בדיוק: Authorized redirect URI = {זהה ל-GOOGLE_CALLBACK_URL}
# עם Nest ‎`setGlobalPrefix('api')`‎ — מקומית: http://localhost:3000/api/auth/google/callback
# Render: ‎`GOOGLE_CALLBACK_URL=https://torlash-server.onrender.com/api/auth/google/callback`‎ (זהה ל-Google Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# CORS: כתובת הפרונט *בדיוק* כפי בדפדפן (בלי ‎/ בסוף) — Netlify, וכו׳
# ב-Render: חייב להיות בדיוק כתובת Netlify (אחרת redirect אחרי Google יחזיר ל-localhost):
# FRONTEND_URL=https://torlash.netlify.app
FRONTEND_URL=http://localhost:5173
# אופציונלי: כמה מקורות (production + netlify deploy preview + local), מופרד בפסיק
# לדוגמה: FRONTEND_URLS=https://torlash.netlify.app,https://xxxxx--project.netlify.app,http://localhost:5173
# FRONTEND_URLS=
# בנוסף ל-‎`FRONTEND_URL` (ממוזגים; ללא כפולים)
# CORS_EXTRA_ORIGINS=
# נתיב אופציונלי לקובץ JSON (אם ריק: client/seed-entities/entities/authorized-users.seed.json)
# AUTHORIZED_USERS_SEED_PATH=
JWT_SECRET=change-me-to-a-long-random-string
# משך בשניות (ברירת מחדל: 7 ימים)
JWT_EXPIRES_IN=604800

# מנהל ראשון ל-MongoDB — לא בקוד / לא ב-git; רק ב־.env מקומי (או הרץ ‎`npm run db:seed`‎ אחרי מילוי)
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_NAME=
# SEED_ADMIN_ROLE=admin
